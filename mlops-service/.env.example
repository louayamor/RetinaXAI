# ── MLflow / DagsHub ──────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=https://dagshub.com/louayamor/retinaxai.mlflow
MLFLOW_TRACKING_USERNAME=louayamor
MLFLOW_TRACKING_PASSWORD=

# ── DVC / DagsHub Remote ─────────────────────────────────────────────────────
DAGSHUB_TOKEN=
DAGSHUB_USERNAME=louayamor

# ── FastAPI Service ───────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ── Inter-Service Communication ───────────────────────────────────────────────
LLMOPS_SERVICE_URL=http://llmops-service:8001
FRONTEND_SERVICE_URL=http://frontend:3000

# ── Shared Storage ────────────────────────────────────────────────────────────
SHARED_UPLOADS_DIR=/app/shared/uploads
SHARED_OUTPUTS_DIR=/app/shared/outputs

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_METRICS_PORT=9090

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/mlops.log

# HuggingFace
HF_TOKEN=your_huggingface_token_here