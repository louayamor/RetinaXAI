APP_ENV=development
APP_NAME=retinaxai-llmops
APP_VERSION=0.1.0

RETINAXAI_BASE_DIR=/home/louay/RetinaXAI

# Inter-service
BACKEND_SERVICE_URL=http://localhost:8000
TIMEOUT_SECONDS=60

# Local storage only
DATA_DIR=/home/louay/RetinaXAI/llmops-service/llmops-service/data
CACHE_DIR=/home/louay/RetinaXAI/llmops-service/llmops-service/data/cache

# LLM Configuration
LLM_PROVIDER=github
LLM_MODEL=openai/gpt-4.1-mini
GITHUB_ACCESS_TOKEN=your_github_token_here

# Prometheus metrics
PROMETHEUS_METRICS_PORT=9092

LOG_LEVEL=INFO
