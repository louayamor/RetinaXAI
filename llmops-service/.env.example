APP_ENV=development
APP_NAME=retinaxai-llmops
APP_VERSION=0.1.0

RETINAXAI_BASE_DIR=/home/louay/RetinaXAI

# Inter-service
BACKEND_SERVICE_URL=http://localhost:8000
TIMEOUT_SECONDS=60

# Storage
SHARED_DIR=shared
OUTPUT_DIR=shared/outputs
VECTORSTORE_DIR=shared/vectorstore
CHROMA_PATH=shared/vectorstore/chroma

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Ollama (if not using OpenAI)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Prometheus metrics
PROMETHEUS_METRICS_PORT=9092

LOG_LEVEL=INFO
